{
  "type": "tabs",
  "items": {
    "tabGeneral": {
      "type": "panel",
      "label": "Allgemein",
      "items": {
        "preset": {
          "type": "select",
          "label": "Schichtmodell",
          "sm": 12,
          "options": [
            { "label": "3-Schicht 21-Tage (NNNNN-WE-SSSSS-WE-FFFFF-WE)", "value": "3schicht_21" },
            { "label": "3-Schicht (FFSSNNXX)",                             "value": "3schicht"    },
            { "label": "2-Schicht (FFSSXX)",                               "value": "2schicht"    },
            { "label": "Kontinuierlicher Betrieb 4-Schicht (FSNX)",        "value": "4schicht"    },
            { "label": "Wechselschicht (FNXX)",                            "value": "wechsel"     },
            { "label": "Benutzerdefiniert",                                "value": "custom"      }
          ],
          "default": "3schicht_21"
        },
        "referenceDate": {
          "newLine": true,
          "type": "text",
          "label": "Referenzdatum – erster Tag des Zyklus (YYYY-MM-DD)",
          "placeholder": "z.B. 2024-01-01",
          "help": "Beim 21-Tage-Modell: erster Montag der Nachtschicht-Woche. Leer = heute.",
          "sm": 12
        }
      }
    },
    "tabCustom": {
      "type": "panel",
      "label": "Benutzerdefiniert",
      "hidden": "data.preset !== 'custom'",
      "items": {
        "customPattern": {
          "type": "text",
          "label": "Schichtmuster (z.B. FFSSNNXX)",
          "placeholder": "FFSSNNXX",
          "help": "Jeder Buchstabe = 1 Tag. Wiederholt sich ab Referenzdatum endlos.",
          "sm": 12
        },
        "customShiftDefs": {
          "newLine": true,
          "type": "table",
          "label": "Schichttypen (einen Eintrag pro Kuerzel aus dem Muster)",
          "sm": 12,
          "items": {
            "key":   { "type": "text",  "label": "Kuerzel",        "width": "80px",  "placeholder": "F"     },
            "label": { "type": "text",  "label": "Bezeichnung",    "placeholder": "Fruehschicht"            },
            "start": { "type": "text",  "label": "Beginn (HH:MM)", "width": "120px", "placeholder": "06:00" },
            "end":   { "type": "text",  "label": "Ende (HH:MM)",   "width": "120px", "placeholder": "14:00" },
            "color": { "type": "color", "label": "Farbe",          "width": "80px"                          }
          }
        }
      }
    },
    "tabVacation": {
      "type": "panel",
      "label": "Urlaub",
      "items": {
        "vacationEntries": {
          "type": "table",
          "label": "Urlaubseintraege (Einzeltag ODER Von+Bis – nicht beides)",
          "sm": 12,
          "items": {
            "date": { "type": "text", "label": "Einzeltag (YYYY-MM-DD)", "placeholder": "2025-07-15" },
            "from": { "type": "text", "label": "Von (YYYY-MM-DD)",       "placeholder": "2025-08-01" },
            "to":   { "type": "text", "label": "Bis (YYYY-MM-DD)",       "placeholder": "2025-08-14" }
          }
        }
      }
    }
  }
}
